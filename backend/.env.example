# --- Server Configuration ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_ENV=development
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# --- Database Configuration ---
# Database driver. Keep the built-in default unless you need PostgreSQL.
DB_DRIVER=
# PostgreSQL connection string (used only when DB_DRIVER=postgres; overrides PG_* below if set)
DB_DSN=
# PostgreSQL split settings (used when DB_DSN is empty)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=echocenter
PG_SSLMODE=disable
# Local database file path
DB_PATH=./data/echo_center.db
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# --- Authentication (MANDATORY) ---
# JWT_SECRET must be a unique, strong random string of at least 32 characters.
JWT_SECRET=your-32-character-secret-key-here-security-critical
JWT_TOKEN_EXPIRATION=24h
BCRYPT_COST=12

# --- Initial Admin Setup ---
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASS=admin123

# --- Butler Service (AI Brain) ---
BUTLER_BASE_URL=https://api.siliconflow.cn/v1
BUTLER_API_TOKEN=your_ai_api_token_here
BUTLER_MODEL=Qwen/Qwen3-8B
BUTLER_CONTEXT_COMPACTION_ENABLED=true
BUTLER_CONTEXT_COMPACTION_BASE_URL=
BUTLER_CONTEXT_COMPACTION_API_TOKEN=
BUTLER_CONTEXT_COMPACTION_MODEL=
BUTLER_CONTEXT_COMPACTION_TRIGGER_MESSAGES=24
BUTLER_CONTEXT_COMPACTION_TRIGGER_CHARS=12000
BUTLER_CONTEXT_COMPACTION_RECENT_WINDOW=8

# --- CORS Configuration ---
# Use comma-separated values for multiple origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Authorization
CORS_MAX_AGE=86400

# --- Feishu Long Connection (WebSocket) ---
# Optional: enable Feishu Socket-mode style inbound bridge.
FEISHU_WS_ENABLED=false
FEISHU_WS_URL=wss://open.feishu.cn/open-apis/ws/v2
FEISHU_WS_RECONNECT_INTERVAL=5s
